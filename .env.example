# Server-only — data access via the service-role key (never exposed to the browser).
# Copy these from the driver-context-manager/.env file.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Public — used by the browser/SSR auth client only (anon key is the public key).
# NEXT_PUBLIC_SUPABASE_URL is the same value as SUPABASE_URL.
# NEXT_PUBLIC_SUPABASE_ANON_KEY is the project's anon key (SUPABASE_KEY in driver-context-manager).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
